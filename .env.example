# Copy to .env.local and fill in your real key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Razorpay Standard Checkout (frontend) — Key ID is public/frontend-safe
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here
# Server-only (set in host dashboard for the /api functions — NEVER commit the secret):
#   RAZORPAY_KEY_ID=...
#   RAZORPAY_KEY_SECRET=...
